---
interface Props {
  title?: string;
}

const { title = "jonathan@portfolio:~" } = Astro.props;
---

<div class="h-screen w-screen flex items-center justify-center p-4 md:p-8">
  <div class="w-full max-w-4xl h-full max-h-[90vh] flex flex-col rounded-lg overflow-hidden shadow-2xl border border-kanagawa-bgLight">
    
    <div class="flex items-center gap-2 px-4 py-3 bg-kanagawa-bgLight shrink-0">
      <span class="w-3 h-3 rounded-full bg-kanagawa-red"></span>
      <span class="w-3 h-3 rounded-full bg-kanagawa-yellow"></span>
      <span class="w-3 h-3 rounded-full bg-kanagawa-green"></span>

      <span class="mx-auto text-kanagawa-fgDim text-sm">
        {title}
      </span>
    </div>

    <div class="flex-1 overflow-y-auto bg-kanagawa-bgDark p-4 md:p-6" id="terminal-body">
      <slot />
    </div>

  </div>
</div>
