---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---


<Layout title="blog">

  <div class="min-h-screen bg-kanagawa-bgDim text-kanagawa-fg px-8 py-6" style="font-family: 'Computer Modern Serif', serif; font-size: 16px;">

    <div class="max-w-3xl mx-auto mb-3 text-center">
      <span class="text-kanagawa-fgDim text-sm">blog</span>
    </div>

    <div class="max-w-3xl mx-auto text-center" style="line-height: 1.6;">
      {posts.map(post => (
        <div style="margin-bottom: 2px;">
          <a href={`/blog/${post.id}`} class="text-kanagawa-cyan hover:text-kanagawa-blue no-underline">{post.data.title}</a>
          <span class="text-kanagawa-fgDim mx-1">·</span>
          <span class="text-kanagawa-green">{post.data.tags.join(' · ')}</span>
          <span class="text-kanagawa-fgDim mx-1">·</span>
          <span class="text-kanagawa-fg">{post.data.date}</span>
          {post.data.modified && (
            <>
              <span class="text-kanagawa-fgDim mx-1">·</span>
              <span class="text-kanagawa-comment">{post.data.modified}</span>
            </>
          )}
        </div>
      ))}
    </div>

  </div>
</Layout>

