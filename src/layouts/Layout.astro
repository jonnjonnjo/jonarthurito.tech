---
import '../styles/global.css'
interface Props {
  title?: string;
}

const { title = "Jonathan Arthurito" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
<script is:inline>
  const saved = localStorage.getItem('theme');
  if (saved) {
    document.documentElement.classList.add(`theme-${saved}`);
  } else {
    const themes = ['wave', 'dragon', 'lotus'];
    const random = themes[Math.floor(Math.random() * themes.length)];
    localStorage.setItem('theme', random);
    document.documentElement.classList.add(`theme-${random}`);
  }
</script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
  <link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
/>  <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/aaaakshat/cm-web-fonts@latest/fonts.css" />
  </head>
  <body class="bg-kanagawa-bgDim text-kanagawa-fg font-mono h-screen w-screen ">
    <slot />
  </body>
</html>
