---
import '../styles/global.css'
import {ClientRouter} from 'astro:transitions';
interface Props {
  title?: string;
}

const { title = "Jonathan Arthurito" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="theme-lotus">
  <head>
<script is:inline>
  const saved = localStorage.getItem('theme');
  if (saved) {
    document.documentElement.classList.replace('theme-lotus', `theme-${saved}`);
  } else {
    localStorage.setItem('theme', 'lotus');
  }
</script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
  <link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
/>  <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/aaaakshat/cm-web-fonts@latest/fonts.css" />
  </head>
  
  <body class="bg-kanagawa-bgDim text-kanagawa-fg font-sans h-screen w-screen overflow-hidden">
    <slot />
    
<script>
  let leaderActive = false;
  let leaderTimeout: ReturnType<typeof setTimeout> | null = null;

  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

    if (e.code === 'Space') {
      e.preventDefault();
      leaderActive = true;
      if (leaderTimeout) clearTimeout(leaderTimeout);
      leaderTimeout = setTimeout(() => { leaderActive = false; }, 700);
      return;
    }

    if (leaderActive) {
      const key = e.key.toLowerCase();
      if (key === 'q') {
        const path = window.location.pathname;
        if (path === '/blog' || path === '/blog/') window.location.href = '/';
        else if (path.startsWith('/blog/')) window.location.href = '/blog';
      } else if (key === 'e') {
        document.dispatchEvent(new CustomEvent('toggle-toc'));
      }
      leaderActive = false;
      if (leaderTimeout) clearTimeout(leaderTimeout);
    }
  });
</script>
  </body>
</html>
